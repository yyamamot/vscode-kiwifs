{
  "name": "vscode-kiwifs",
  "displayName": "kiwifs",
  "publisher": "yyamamot",
  "description": "VS Code extension bootstrap for Kiwi TCMS virtual filesystem integration",
  "categories": [
    "Other"
  ],
  "version": "0.0.6",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yyamamot/vscode-kiwifs.git"
  },
  "packageManager": "pnpm@10.30.3",
  "type": "commonjs",
  "engines": {
    "vscode": "^1.105.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onFileSystem:kiwi",
    "onCommand:kiwi.openRoot",
    "onCommand:kiwi.searchCases",
    "onCommand:kiwi.filterCases",
    "onCommand:kiwi.filterTestRuns",
    "onCommand:kiwi.openTestRunDashboard",
    "onCommand:kiwi.configureBaseUrl",
    "onCommand:kiwi.configureUsername",
    "onCommand:kiwi.configurePassword",
    "onCommand:kiwi.clearBaseUrl",
    "onCommand:kiwi.clearUsername",
    "onCommand:kiwi.clearPassword",
    "onCommand:kiwi.clearConfiguration",
    "onCommand:kiwi.refreshPlans",
    "onCommand:kiwi.openTreeItem",
    "onCommand:kiwi.showPlanInfo",
    "onCommand:kiwi.createCase",
    "onCommand:kiwi.addExistingCaseToPlan",
    "onCommand:kiwi.removeCaseFromPlan",
    "onCommand:kiwi.removeCaseFromPlanFromPlan",
    "onCommand:kiwi.deleteCase",
    "onCommand:kiwi.downloadPlanToLocalMirror",
    "onCommand:kiwi.comparePlanLocalMirror",
    "onCommand:kiwi.uploadPlanLocalMirror",
    "onCommand:kiwi.refreshCaseDocument",
    "onCommand:kiwi.checkCaseFreshness",
    "onCommand:kiwi.showCaseDiff",
    "onCommand:kiwi.showCaseHistoryDiff",
    "onCommand:kiwi.showCaseHistory",
    "onCommand:kiwi.showCaseInfo",
    "onCommand:kiwi.editCaseMetadata",
    "onCommand:kiwi.duplicateCase",
    "onCommand:kiwi.manageCaseExecutionsAcrossRuns",
    "onCommand:kiwi.recordCaseExecutionResult",
    "onCommand:kiwi.showCaseAttachments",
    "onCommand:kiwi.addCaseAttachment",
    "onCommand:kiwi.openCaseAttachmentInBrowser",
    "onCommand:kiwi.openCaseAttachmentInEditor",
    "onCommand:kiwi.openInBrowser",
    "onCommand:kiwi.openPlanInBrowser",
    "onCommand:kiwi.downloadCaseToLocalMirror",
    "onCommand:kiwi.compareLocalMirror",
    "onCommand:kiwi.uploadLocalMirror",
    "onCommand:kiwi.scmCompareLocalMirrorAgain",
    "onCommand:kiwi.scmCheckRemoteLocalMirrorMetadata",
    "onCommand:kiwi.scmUploadLocalMirrorResources",
    "onCommand:kiwi.scmTakeRemoteLocalMirrorResources",
    "onCommand:kiwi.revealLocalMirror",
    "onCommand:kiwi.installLlmSkillPack",
    "onCommand:kiwi.startLlmEditSession",
    "onCommand:kiwi.createLlmLocalMirrorDiffContext",
    "onCommand:kiwi.clearRuntimeLogs",
    "onCommand:kiwi.revealRuntimeLogs",
    "onCommand:kiwi.showTreeItemActions",
    "onCommand:kiwi.showPlanTreeItemActions",
    "onCommand:kiwi.showCaseTreeItemActions"
  ],
  "contributes": {
    "commands": [
      {
        "command": "kiwi.openRoot",
        "title": "%command.kiwi.openRoot.title%"
      },
      {
        "command": "kiwi.searchCases",
        "title": "%command.kiwi.searchCases.title%",
        "icon": "$(search)"
      },
      {
        "command": "kiwi.filterCases",
        "title": "%command.kiwi.filterCases.title%",
        "icon": "$(search)"
      },
      {
        "command": "kiwi.filterTestRuns",
        "title": "%command.kiwi.filterTestRuns.title%",
        "icon": "$(search)"
      },
      {
        "command": "kiwi.openTestRunDashboard",
        "title": "%command.kiwi.openTestRunDashboard.title%",
        "icon": "$(play-circle)"
      },
      {
        "command": "kiwi.configureBaseUrl",
        "title": "%command.kiwi.configureBaseUrl.title%"
      },
      {
        "command": "kiwi.configureUsername",
        "title": "%command.kiwi.configureUsername.title%"
      },
      {
        "command": "kiwi.configurePassword",
        "title": "%command.kiwi.configurePassword.title%"
      },
      {
        "command": "kiwi.clearBaseUrl",
        "title": "%command.kiwi.clearBaseUrl.title%"
      },
      {
        "command": "kiwi.clearUsername",
        "title": "%command.kiwi.clearUsername.title%"
      },
      {
        "command": "kiwi.clearPassword",
        "title": "%command.kiwi.clearPassword.title%"
      },
      {
        "command": "kiwi.clearConfiguration",
        "title": "%command.kiwi.clearConfiguration.title%"
      },
      {
        "command": "kiwi.refreshPlans",
        "title": "%command.kiwi.refreshPlans.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "kiwi.openTreeItem",
        "title": "%command.kiwi.openTreeItem.title%"
      },
      {
        "command": "kiwi.showTreeItemActions",
        "title": "%command.kiwi.showTreeItemActions.title%",
        "icon": "$(list-selection)"
      },
      {
        "command": "kiwi.showPlanTreeItemActions",
        "title": "%command.kiwi.showPlanTreeItemActions.title%",
        "icon": "$(list-selection)"
      },
      {
        "command": "kiwi.showCaseTreeItemActions",
        "title": "%command.kiwi.showCaseTreeItemActions.title%",
        "icon": "$(list-selection)"
      },
      {
        "command": "kiwi.showPlanInfo",
        "title": "%command.kiwi.showPlanInfo.title%"
      },
      {
        "command": "kiwi.createCase",
        "title": "%command.kiwi.createCase.title%"
      },
      {
        "command": "kiwi.addExistingCaseToPlan",
        "title": "%command.kiwi.addExistingCaseToPlan.title%"
      },
      {
        "command": "kiwi.removeCaseFromPlan",
        "title": "%command.kiwi.removeCaseFromPlan.title%"
      },
      {
        "command": "kiwi.removeCaseFromPlanFromPlan",
        "title": "%command.kiwi.removeCaseFromPlanFromPlan.title%"
      },
      {
        "command": "kiwi.deleteCase",
        "title": "%command.kiwi.deleteCase.title%"
      },
      {
        "command": "kiwi.downloadPlanToLocalMirror",
        "title": "%command.kiwi.downloadPlanToLocalMirror.title%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "kiwi.comparePlanLocalMirror",
        "title": "%command.kiwi.comparePlanLocalMirror.title%",
        "icon": "$(diff)"
      },
      {
        "command": "kiwi.uploadPlanLocalMirror",
        "title": "%command.kiwi.uploadPlanLocalMirror.title%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "kiwi.refreshCaseDocument",
        "title": "%command.kiwi.refreshCaseDocument.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "kiwi.checkCaseFreshness",
        "title": "%command.kiwi.checkCaseFreshness.title%",
        "icon": "$(sync)"
      },
      {
        "command": "kiwi.showCaseDiff",
        "title": "%command.kiwi.showCaseDiff.title%",
        "icon": "$(diff)"
      },
      {
        "command": "kiwi.showCaseHistoryDiff",
        "title": "%command.kiwi.showCaseHistoryDiff.title%",
        "icon": "$(history)"
      },
      {
        "command": "kiwi.showCaseHistory",
        "title": "%command.kiwi.showCaseHistory.title%",
        "icon": "$(list-tree)"
      },
      {
        "command": "kiwi.showCaseInfo",
        "title": "%command.kiwi.showCaseInfo.title%"
      },
      {
        "command": "kiwi.editCaseMetadata",
        "title": "%command.kiwi.editCaseMetadata.title%"
      },
      {
        "command": "kiwi.duplicateCase",
        "title": "%command.kiwi.duplicateCase.title%"
      },
      {
        "command": "kiwi.recordCaseExecutionResult",
        "title": "%command.kiwi.recordCaseExecutionResult.title%"
      },
      {
        "command": "kiwi.manageCaseExecutionsAcrossRuns",
        "title": "%command.kiwi.manageCaseExecutionsAcrossRuns.title%"
      },
      {
        "command": "kiwi.showCaseAttachments",
        "title": "%command.kiwi.showCaseAttachments.title%"
      },
      {
        "command": "kiwi.addCaseAttachment",
        "title": "%command.kiwi.addCaseAttachment.title%"
      },
      {
        "command": "kiwi.openCaseAttachmentInBrowser",
        "title": "%command.kiwi.openCaseAttachmentInBrowser.title%"
      },
      {
        "command": "kiwi.openCaseAttachmentInEditor",
        "title": "%command.kiwi.openCaseAttachmentInEditor.title%"
      },
      {
        "command": "kiwi.openInBrowser",
        "title": "%command.kiwi.openInBrowser.title%",
        "icon": "$(globe)"
      },
      {
        "command": "kiwi.openPlanInBrowser",
        "title": "%command.kiwi.openPlanInBrowser.title%",
        "icon": "$(globe)"
      },
      {
        "command": "kiwi.downloadCaseToLocalMirror",
        "title": "%command.kiwi.downloadCaseToLocalMirror.title%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "kiwi.compareLocalMirror",
        "title": "%command.kiwi.compareLocalMirror.title%",
        "icon": "$(diff)"
      },
      {
        "command": "kiwi.uploadLocalMirror",
        "title": "%command.kiwi.uploadLocalMirror.title%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "kiwi.scmCompareLocalMirrorAgain",
        "title": "%command.kiwi.scmCompareLocalMirrorAgain.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "kiwi.scmCheckRemoteLocalMirrorMetadata",
        "title": "%command.kiwi.scmCheckRemoteLocalMirrorMetadata.title%",
        "icon": "$(sync)"
      },
      {
        "command": "kiwi.scmUploadLocalMirrorResources",
        "title": "%command.kiwi.scmUploadLocalMirrorResources.title%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "kiwi.scmTakeRemoteLocalMirrorResources",
        "title": "%command.kiwi.scmTakeRemoteLocalMirrorResources.title%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "kiwi.revealLocalMirror",
        "title": "%command.kiwi.revealLocalMirror.title%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "kiwi.installLlmSkillPack",
        "title": "%command.kiwi.installLlmSkillPack.title%",
        "icon": "$(book)"
      },
      {
        "command": "kiwi.startLlmEditSession",
        "title": "%command.kiwi.startLlmEditSession.title%",
        "icon": "$(sparkle)"
      },
      {
        "command": "kiwi.createLlmLocalMirrorDiffContext",
        "title": "%command.kiwi.createLlmLocalMirrorDiffContext.title%",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "kiwi.clearRuntimeLogs",
        "title": "%command.kiwi.clearRuntimeLogs.title%",
        "icon": "$(trash)"
      },
      {
        "command": "kiwi.revealRuntimeLogs",
        "title": "%command.kiwi.revealRuntimeLogs.title%",
        "icon": "$(folder-opened)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "kiwiPlans",
          "name": "Kiwi Plans"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "kiwiPlans",
        "contents": "%view.kiwiPlans.welcome.setup%",
        "when": "config.kiwi.baseUrl == ''"
      },
      {
        "view": "kiwiPlans",
        "contents": "%view.kiwiPlans.welcome.open%",
        "when": "config.kiwi.baseUrl != ''"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kiwi.filterCases",
          "when": "view == kiwiPlans",
          "group": "navigation@1"
        },
        {
          "command": "kiwi.openTestRunDashboard",
          "when": "view == kiwiPlans",
          "group": "navigation@2"
        },
        {
          "command": "kiwi.filterTestRuns",
          "when": "view == kiwiPlans",
          "group": "navigation@3"
        },
        {
          "command": "kiwi.refreshPlans",
          "when": "view == kiwiPlans",
          "group": "navigation@4"
        },
        {
          "command": "kiwi.clearRuntimeLogs",
          "when": "view == kiwiPlans && kiwi.runtimeLogsEnabled",
          "group": "navigation@5"
        },
        {
          "command": "kiwi.revealRuntimeLogs",
          "when": "view == kiwiPlans && kiwi.runtimeLogsEnabled",
          "group": "navigation@6"
        }
      ],
      "commandPalette": [
        {
          "command": "kiwi.searchCases",
          "when": "false"
        },
        {
          "command": "kiwi.clearRuntimeLogs",
          "when": "kiwi.runtimeLogsEnabled"
        },
        {
          "command": "kiwi.revealRuntimeLogs",
          "when": "kiwi.runtimeLogsEnabled"
        },
        {
          "command": "kiwi.deleteCase",
          "when": "false"
        },
        {
          "command": "kiwi.removeCaseFromPlanFromPlan",
          "when": "false"
        },
        {
          "command": "kiwi.scmUploadLocalMirrorResources",
          "when": "false"
        },
        {
          "command": "kiwi.scmCompareLocalMirrorAgain",
          "when": "false"
        },
        {
          "command": "kiwi.scmCheckRemoteLocalMirrorMetadata",
          "when": "false"
        },
        {
          "command": "kiwi.scmTakeRemoteLocalMirrorResources",
          "when": "false"
        },
        {
          "command": "kiwi.uploadLocalMirror",
          "when": "false"
        },
        {
          "command": "kiwi.uploadPlanLocalMirror",
          "when": "false"
        },
        {
          "command": "kiwi.showTreeItemActions",
          "when": "false"
        },
        {
          "command": "kiwi.showPlanTreeItemActions",
          "when": "false"
        },
        {
          "command": "kiwi.showCaseTreeItemActions",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "kiwi.openPlanInBrowser",
          "when": "view == kiwiPlans && viewItem == plan",
          "group": "01_open@1"
        },
        {
          "command": "kiwi.showPlanTreeItemActions",
          "when": "view == kiwiPlans && viewItem == plan",
          "group": "02_inspect@1"
        },
        {
          "command": "kiwi.createCase",
          "when": "view == kiwiPlans && viewItem == plan",
          "group": "03_structureEdit@1"
        },
        {
          "command": "kiwi.addExistingCaseToPlan",
          "when": "view == kiwiPlans && viewItem == plan",
          "group": "03_structureEdit@2"
        },
        {
          "command": "kiwi.downloadPlanToLocalMirror",
          "when": "view == kiwiPlans && viewItem == plan",
          "group": "04_localMirror@1"
        },
        {
          "command": "kiwi.comparePlanLocalMirror",
          "when": "view == kiwiPlans && viewItem == plan",
          "group": "04_localMirror@2"
        },
        {
          "command": "kiwi.openInBrowser",
          "when": "view == kiwiPlans && viewItem == caseDocument",
          "group": "01_open@1"
        },
        {
          "command": "kiwi.refreshCaseDocument",
          "when": "view == kiwiPlans && viewItem == caseDocument",
          "group": "02_inspect@1"
        },
        {
          "command": "kiwi.editCaseMetadata",
          "when": "view == kiwiPlans && viewItem == caseDocument",
          "group": "02_inspect@2"
        },
        {
          "command": "kiwi.manageCaseExecutionsAcrossRuns",
          "when": "view == kiwiPlans && viewItem == caseDocument",
          "group": "02_inspect@3"
        },
        {
          "command": "kiwi.showCaseTreeItemActions",
          "when": "view == kiwiPlans && viewItem == caseDocument",
          "group": "02_inspect@4"
        },
        {
          "command": "kiwi.downloadCaseToLocalMirror",
          "when": "view == kiwiPlans && viewItem == caseDocument",
          "group": "04_localMirror@1"
        },
        {
          "command": "kiwi.compareLocalMirror",
          "when": "view == kiwiPlans && viewItem == caseDocument",
          "group": "04_localMirror@2"
        },
        {
          "command": "kiwi.removeCaseFromPlan",
          "when": "view == kiwiPlans && viewItem == caseDocument",
          "group": "06_danger@1"
        },
        {
          "command": "kiwi.deleteCase",
          "when": "view == kiwiPlans && viewItem == caseDocument",
          "group": "06_danger@2"
        }
      ],
      "editor/title": [
        {
          "command": "kiwi.checkCaseFreshness",
          "when": "resourceScheme == kiwi && resourcePath =~ /\\/cases\\/.+\\.md$/",
          "group": "navigation@2"
        },
        {
          "command": "kiwi.openInBrowser",
          "when": "resourceScheme == kiwi && resourcePath =~ /\\/cases\\/.+\\.md$/",
          "group": "navigation@3"
        }
      ],
      "scm/repository": [
        {
          "command": "kiwi.scmCompareLocalMirrorAgain",
          "when": "scmProvider == kiwi-local-mirror-compare",
          "group": "inline@1"
        },
        {
          "command": "kiwi.scmCheckRemoteLocalMirrorMetadata",
          "when": "scmProvider == kiwi-local-mirror-compare",
          "group": "inline@2"
        },
        {
          "command": "kiwi.scmUploadLocalMirrorResources",
          "when": "scmProvider == kiwi-local-mirror-compare",
          "group": "inline@3"
        },
        {
          "command": "kiwi.scmTakeRemoteLocalMirrorResources",
          "when": "scmProvider == kiwi-local-mirror-compare",
          "group": "inline@4"
        },
        {
          "command": "kiwi.startLlmEditSession",
          "when": "scmProvider == kiwi-local-mirror-compare",
          "group": "inline@5"
        },
        {
          "command": "kiwi.createLlmLocalMirrorDiffContext",
          "when": "scmProvider == kiwi-local-mirror-compare",
          "group": "inline@6"
        }
      ],
      "scm/resourceGroup/context": [
        {
          "command": "kiwi.scmUploadLocalMirrorResources",
          "when": "scmProvider == kiwi-local-mirror-compare && scmResourceGroup == changes",
          "group": "navigation@1"
        },
        {
          "command": "kiwi.scmTakeRemoteLocalMirrorResources",
          "when": "scmProvider == kiwi-local-mirror-compare && scmResourceGroup == remoteChanged",
          "group": "navigation@1"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "kiwi.scmUploadLocalMirrorResources",
          "when": "scmProvider == kiwi-local-mirror-compare && scmResourceState == kiwi.localChanged",
          "group": "navigation@1"
        },
        {
          "command": "kiwi.scmTakeRemoteLocalMirrorResources",
          "when": "scmProvider == kiwi-local-mirror-compare && scmResourceState == kiwi.remoteChanged",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "Kiwi FS",
      "properties": {
        "kiwi.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Kiwi TCMS base URL used outside local development."
        }
      }
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint stub: no linter configured yet')\"",
    "format": "node -e \"console.log('format stub: no formatter configured yet')\"",
    "build": "node ./scripts/build.mjs",
    "build:test": "tsc -p tsconfig.json",
    "dev:vscode": "node ./scripts/open-clean-vscode.mjs",
    "package:vsix": "node ./scripts/vsix.mjs package",
    "install:vsix": "node ./scripts/vsix.mjs install",
    "uninstall:vsix": "node ./scripts/vsix.mjs uninstall",
    "review:ui:feature": "node ./scripts/review-ui-feature.mjs",
    "review:ui:llm:scenario": "node ./scripts/review-ui-llm.mjs",
    "verify:ui-change": "node ./scripts/verify-ui-change.mjs",
    "test:unit": "vitest run --dir test/unit",
    "test:integration": "vitest run --dir test/integration",
    "test:integration:host": "pnpm run build && pnpm run build:test && node ./out/test/integration-host/run.js",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test:unit",
    "verify": "pnpm run build && pnpm run check:l10n && pnpm run test:unit && pnpm run test:integration && pnpm run test:integration:host",
    "check:l10n": "node ./scripts/check-l10n.mjs",
    "check:release-ui-text": "node ./scripts/check-release-ui-text.mjs"
  },
  "files": [
    "dist/**",
    "assets/**",
    "README.md",
    "README.ja.md",
    "CHANGELOG.md",
    "CHANGELOG.ja.md",
    "LICENSE",
    "package.json",
    "l10n/**",
    "package.nls.json",
    "package.nls.ja.json"
  ],
  "devDependencies": {
    "esbuild": "^0.27.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.3.0",
    "@types/vscode": "^1.105.0",
    "@types/xmlrpc": "^1.3.10",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "mocha": "^11.7.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "yaml": "^2.8.1"
  },
  "dependencies": {
    "xmlrpc": "^1.3.2"
  },
  "l10n": "./l10n"
}
